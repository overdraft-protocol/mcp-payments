{
  "name": "@overdraft/mpx",
  "version": "0.1.0",
  "description": "Transport-safe, in-band payment extension for MCP servers. Rail-agnostic core with pluggable settlement rails.",
  "license": "MIT",
  "author": "Overdraft",
  "type": "module",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "payments",
    "x402",
    "agents",
    "ai-agents",
    "stablecoin",
    "usdc",
    "json-rpc",
    "mpx",
    "mcp-payments",
    "mcp-payment-extension"
  ],
  "homepage": "https://github.com/overdraft-protocol/mcp-payments#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/overdraft-protocol/mcp-payments.git"
  },
  "bugs": {
    "url": "https://github.com/overdraft-protocol/mcp-payments/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./rails/x402-evm": {
      "import": "./dist/rails/x402-evm/index.js",
      "types": "./dist/rails/x402-evm/index.d.ts"
    },
    "./rails/dev-signature": {
      "import": "./dist/rails/dev-signature/index.js",
      "types": "./dist/rails/dev-signature/index.d.ts"
    },
    "./rails/stripe": {
      "import": "./dist/rails/stripe/index.js",
      "types": "./dist/rails/stripe/index.d.ts"
    },
    "./server/payment-log": {
      "import": "./dist/server/payment-log.js",
      "types": "./dist/server/payment-log.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "x402": "^1.2.0",
    "viem": "^2.30.0",
    "stripe": "^17.0.0"
  },
  "peerDependenciesMeta": {
    "x402": { "optional": true },
    "viem": { "optional": true },
    "stripe": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
